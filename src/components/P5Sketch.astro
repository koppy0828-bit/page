---
// src/components/P5Sketch.astro
---
<div id="p5-container"></div>

<script>
  import p5 from 'p5';

  const sketch = (p) => {
    let x = 100;
    let y = 100;

    p.setup = () => {
      // 親要素の幅に合わせてキャンバスを作成
      const container = document.getElementById('p5-container');
      p.createCanvas(container.offsetWidth, 400).parent(container);
    };

    p.draw = () => {
      p.background(20, 20, 30); // 深い紺色（バイブス！）
      p.noStroke();
      
      // マウスに追従する光る円
      let targetX = p.mouseX;
      let targetY = p.mouseY;
      x += (targetX - x) * 0.1;
      y += (targetY - y) * 0.1;

      for (let i = 10; i > 0; i--) {
        p.fill(0, 255, 200, i * 20);
        p.ellipse(x, y, i * 8);
      }
    };

    p.windowResized = () => {
      const container = document.getElementById('p5-container');
      p.resizeCanvas(container.offsetWidth, 400);
    };
  };

  new p5(sketch);
</script>

<style>
  #p5-container {
    width: 100%;
    height: 400px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }
</style>