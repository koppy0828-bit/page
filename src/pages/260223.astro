---
import Layout from '../layouts/Layout.astro';
import Sketch260223 from '../components/Sketch260223.astro';
---

<Layout title="Kosei">
  <main>
    <h1>260223.</h1>
    <a href="/">← Topへ戻る</a>
    <div class="canvas-wrapper">
      <Sketch260223 />
    </div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 2rem;
    /* 額縁を大きく：max-widthを800pxから1200pxなどに広げる */
    max-width: 1200px;
    width: 90%;
  }

  h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .canvas-wrapper {
    /* P5の周りに少し余裕を持たせる */
    margin-top: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
  }
</style>